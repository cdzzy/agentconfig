{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/cdzzy/agentconfig/schemas/agent-config.schema.json",
  "title": "AgentConfig",
  "description": "Complete, executable configuration for an AI agent. This schema enables IDE autocomplete and validation for agent configuration files.",
  "type": "object",
  "required": ["name"],
  "additionalProperties": false,
  "properties": {
    "config_id": {
      "type": "string",
      "description": "Unique identifier for this configuration. Auto-generated if not provided.",
      "minLength": 1,
      "maxLength": 36
    },
    "name": {
      "type": "string",
      "description": "Human-readable name for the agent.",
      "minLength": 1,
      "maxLength": 200,
      "examples": ["Customer Support Bot", "Sales Assistant"]
    },
    "version": {
      "type": "string",
      "description": "Semantic version of this configuration.",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "default": "1.0.0",
      "examples": ["1.0.0", "2.1.3"]
    },
    "created_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of when this config was created. Auto-generated if not provided.",
      "format": "date-time"
    },
    "description": {
      "type": "string",
      "description": "Brief description of what this agent does.",
      "maxLength": 1000,
      "default": ""
    },
    "system_prompt": {
      "type": "string",
      "description": "System prompt that defines the agent's behavior. Can be auto-generated from intent.",
      "default": ""
    },
    "intent": {
      "$ref": "#/definitions/AgentIntent",
      "description": "Structured intent describing what the business user wants from this agent."
    },
    "model": {
      "$ref": "#/definitions/ModelConfig",
      "description": "LLM model configuration."
    },
    "constraints": {
      "type": "array",
      "description": "List of business rule constraints to enforce on agent responses.",
      "items": {
        "$ref": "#/definitions/Constraint"
      },
      "default": []
    },
    "tools_enabled": {
      "type": "array",
      "description": "List of tool names this agent is allowed to use.",
      "items": {
        "type": "string"
      },
      "default": [],
      "examples": [["web_search", "calculator", "file_read"]]
    },
    "tools_disabled": {
      "type": "array",
      "description": "List of tool names explicitly disabled for this agent.",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "max_turns": {
      "type": "integer",
      "description": "Maximum number of conversation turns before the session ends.",
      "minimum": 1,
      "maximum": 1000,
      "default": 20
    },
    "stream": {
      "type": "boolean",
      "description": "Whether to stream responses token by token.",
      "default": false
    },
    "log_enabled": {
      "type": "boolean",
      "description": "Whether to log agent interactions for debugging.",
      "default": true
    },
    "audit_enabled": {
      "type": "boolean",
      "description": "Whether to enable audit logging for compliance.",
      "default": true
    },
    "metadata": {
      "type": "object",
      "description": "Custom metadata key-value pairs from business users.",
      "additionalProperties": true,
      "default": {}
    },
    "mcp_servers": {
      "type": "array",
      "description": "List of MCP (Model Context Protocol) server declarations for tool integration.",
      "items": {
        "$ref": "#/definitions/MCPServerConfig"
      },
      "default": []
    },
    "tool_policy": {
      "oneOf": [
        {"$ref": "#/definitions/ToolPolicy"},
        {"type": "null"}
      ],
      "description": "Policy controlling which MCP tools the agent is allowed or blocked from using.",
      "default": null
    }
  },
  "definitions": {
    "AgentIntent": {
      "type": "object",
      "description": "Structured representation of what a business user wants from an agent.",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Agent name.",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "description": "What the agent does, 1-2 sentences.",
          "default": ""
        },
        "audience": {
          "type": "string",
          "description": "Who the agent serves.",
          "default": ""
        },
        "domain": {
          "type": "string",
          "description": "Business domain of the agent.",
          "enum": ["customer_service", "sales", "hr", "finance", "it_support", "legal", "marketing", "general"],
          "default": "general"
        },
        "tone": {
          "type": "array",
          "description": "Communication style(s) for the agent.",
          "items": {
            "type": "string",
            "enum": ["professional", "friendly", "formal", "casual", "empathetic", "concise"]
          },
          "default": ["professional"],
          "minItems": 1
        },
        "language": {
          "type": "string",
          "description": "Response language. 'auto' to detect, or ISO code like 'en', 'zh'.",
          "default": "auto"
        },
        "actions_allowed": {
          "type": "array",
          "description": "Things the agent is explicitly allowed to do.",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "actions_forbidden": {
          "type": "array",
          "description": "Things the agent must never do.",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "topics_forbidden": {
          "type": "array",
          "description": "Topics the agent must never discuss.",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "escalation_triggers": {
          "type": "array",
          "description": "Conditions that require human handoff.",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "max_turns": {
          "type": "integer",
          "description": "Maximum conversation turns.",
          "minimum": 1,
          "maximum": 1000,
          "default": 20
        },
        "require_confirmation": {
          "type": "array",
          "description": "Actions that need user confirmation before proceeding.",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "goals": {
          "type": "array",
          "description": "Success criteria for the agent.",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "ModelConfig": {
      "type": "object",
      "description": "LLM model configuration.",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "description": "LLM provider.",
          "enum": ["openai", "anthropic", "ollama", "azure", "google", "mistral", "cohere", "custom"],
          "default": "openai"
        },
        "model": {
          "type": "string",
          "description": "Model identifier.",
          "default": "gpt-4o-mini",
          "examples": ["gpt-4o", "gpt-4o-mini", "claude-3-5-sonnet-20241022", "llama3"]
        },
        "temperature": {
          "type": "number",
          "description": "Sampling temperature. Higher = more creative, lower = more deterministic.",
          "minimum": 0,
          "maximum": 2,
          "default": 0.7
        },
        "max_tokens": {
          "type": "integer",
          "description": "Maximum tokens in the response.",
          "minimum": 1,
          "maximum": 128000,
          "default": 1024
        },
        "top_p": {
          "type": "number",
          "description": "Nucleus sampling parameter.",
          "minimum": 0,
          "maximum": 1,
          "default": 1.0
        },
        "timeout_seconds": {
          "type": "integer",
          "description": "Request timeout in seconds.",
          "minimum": 1,
          "maximum": 600,
          "default": 30
        },
        "api_base": {
          "type": ["string", "null"],
          "description": "Custom API endpoint URL. For Ollama or other self-hosted models.",
          "default": null,
          "examples": ["http://localhost:11434/v1"]
        }
      }
    },
    "Constraint": {
      "type": "object",
      "description": "A single business rule constraint.",
      "required": ["id", "type", "description"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for this constraint.",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "description": "Type of constraint.",
          "enum": ["forbidden_topic", "forbidden_keyword", "max_length", "min_length", "required_keyword", "tone_check", "escalation", "custom"]
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of this constraint.",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "description": "What to do when this constraint is violated.",
          "enum": ["block", "warn", "replace", "escalate"],
          "default": "block"
        },
        "fallback_message": {
          "type": "string",
          "description": "Message to show when action is 'replace'.",
          "default": "I'm sorry, I can't help with that. Please contact our team directly."
        },
        "keywords": {
          "type": "array",
          "description": "Keywords for FORBIDDEN/REQUIRED_KEYWORD type constraints.",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "pattern": {
          "type": "string",
          "description": "Regex pattern for CUSTOM type constraints.",
          "default": ""
        },
        "max_chars": {
          "type": "integer",
          "description": "Maximum character count for MAX_LENGTH type constraints.",
          "minimum": 0,
          "default": 0
        },
        "min_chars": {
          "type": "integer",
          "description": "Minimum character count for MIN_LENGTH type constraints.",
          "minimum": 0,
          "default": 0
        }
      }
    },
    "MCPServerConfig": {
      "type": "object",
      "description": "Configuration for a single MCP server providing tools to the agent.",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique name for this MCP server.",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "description": "Command to start the MCP server (e.g. 'npx', 'python').",
          "default": ""
        },
        "args": {
          "type": "array",
          "description": "Command-line arguments for the MCP server.",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "env": {
          "type": "object",
          "description": "Environment variables for the MCP server. Use ${VAR} for secrets.",
          "additionalProperties": {
            "type": "string"
          },
          "default": {}
        },
        "url": {
          "type": ["string", "null"],
          "description": "URL for SSE-based MCP servers.",
          "default": null
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of this MCP server.",
          "default": ""
        },
        "tools": {
          "type": "array",
          "description": "List of tool names this server provides.",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "ToolPolicy": {
      "type": "object",
      "description": "Policy controlling which MCP tools the agent is allowed or blocked from using.",
      "additionalProperties": false,
      "properties": {
        "allowed_tools": {
          "type": "array",
          "description": "Tools the agent is explicitly allowed to use (format: server:tool).",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "blocked_tools": {
          "type": "array",
          "description": "Tools the agent is blocked from using (format: server:tool).",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "auto_approve": {
          "type": "boolean",
          "description": "Whether to auto-approve tool calls without human confirmation.",
          "default": false
        },
        "require_confirmation": {
          "type": "array",
          "description": "Tools that require human approval before use (format: server:tool).",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    }
  }
}
